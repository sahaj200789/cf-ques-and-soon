#include <iostream>
#include <vector>
#include <algorithm>
#include <string>
using namespace std;

vector<long long> getTruckWeights(vector<long long>& vec, long long k) {
    vector<long long> truck_weights;
    long long current_truck_sum = 0;
    
    for (int i = 0; i < vec.size(); i++) {
        current_truck_sum += vec[i];
        
        
        if ((i + 1) % k == 0) {
            truck_weights.push_back(current_truck_sum);
            current_truck_sum = 0; 
        }
    }
    
    return truck_weights;
}



int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);

    int t;
    if (cin >> t) {
        while (t--) {
            long long n;
            cin >> n ;

            vector<long long>vec(n);

            for(int i=0;i<n;i++){
                cin>>vec[i];
            }
            long long ans=0;

            vector<long long>num;
            for(int i=1;i<=n;i++){
                if(n%i==0){
                    num = getTruckWeights(vec,i);
                    sort(num.begin(),num.end());
                    ans= max(ans,(num[num.size()-1]-num[0]));
                }

            }

            cout<<ans<<endl;           
        }
    }
    return 0;
}
