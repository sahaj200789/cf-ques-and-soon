#include <iostream>  // nice approach but tle ...
#include <string>
#include <vector>
#include <algorithm>
#include <cmath>
using namespace std;

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);

    int t;
    cin >> t;

    while (t--) {
        long long n;
        cin>>n;

        vector<long long>vec(n);
        for(int i=0;i<n;i++){
            cin>>vec[i];
        }

        vector<long long>num(n);
        for(int i=0;i<n;i++){
            num[i]=vec[i];
        }

        sort(num.begin(),num.end());

        vector<long long>b(n+1);
        b[(n)/2]=0; // FIXED: Headquarter position initialized to 0 index value instead of -1

        // FIXED: Balanced alternating placement for both even and odd arrays
        long long val = n - 1;
        for(int i = (n/2) + 1; i < n + 1; i++){
            if(val >= 0) {
                b[i] = num[val];
                val -= 2;
            }
        }

        long long ans = n - 2;
        for(int i = (n/2) - 1; i >= 0; i--){
            if(ans >= 0) {
                b[i] = num[ans];
                ans -= 2;
            }
        }

        long long count=0;
        for(int i=0;i<n+1;i++){
            if(i!=n/2){
                count+=2*abs(n/2-i)*b[i];
            }            
        }
        cout<<count<<"\n";

        // FIXED: Maps your computed locations back to their original building sequence order
        vector<long long>a(n+1);
        a[0] = 0; // Headquarter coordinate is 0

        for(int i=0; i<n; i++) {
            for(int j=0; j<n+1; j++) {
                if(j != n/2 && b[j] == vec[i]) {
                    // Convert the absolute array index j into a relative coordinate distance
                    a[i+1] = j - (n/2); 
                    b[j] = -999999999; // Placeholder to avoid matching this coordinate again
                    break;
                }
            }
        }

        // Print final coordinate positions
        for(int i=0; i<n+1; i++) {
            cout << a[i] << " ";
        }
        cout << "\n";
    }
    return 0;
}
